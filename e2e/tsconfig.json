{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "types": ["node", "mocha"]
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  },
  "include": [
    "./**/*.ts",
    "./node_modules/@wdio/globals/types.d.ts",
    "./node_modules/webdriverio/build/types.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}